# .env는 반드시 KEY=value 형식으로 작성하세요.
# 잘못된 예: KEY = value (등호 주변 공백 금지)

# Required
# 브이월드 API 키를 입력하세요.
# 발급처: https://www.vworld.kr/dev/vkey.do
VWORLD_WMTS_KEY=YOUR_WMTS_KEY_HERE
VWORLD_GEOCODER_KEY=YOUR_GEOCODER_KEY_HERE
ADMIN_ID=YOUR_ADMIN_ID_HERE
# 초기 비밀번호: 12345678
ADMIN_PW_HASH=$2b$12$iaY7OeourURbA9QW1t4TheiRqFcq1bAh83Dihl3zLaDVzg5OvhujC
SECRET_KEY=replace-with-long-random-secret

# App
APP_NAME="관심 필지 지도 (Parcel Explorer)"
MAP_CENTER_LAT=36.7848
MAP_CENTER_LON=126.4500
MAP_DEFAULT_ZOOM=13

# Session / Access Control
SESSION_COOKIE_NAME=session
SESSION_NAMESPACE=parcel-explorer
ALLOWED_IPS=127.0.0.1/32,::1/128
SESSION_HTTPS_ONLY=false

# Login Rate Limit
LOGIN_MAX_ATTEMPTS=5
LOGIN_COOLDOWN_SECONDS=300

# VWorld / External API
VWORLD_TIMEOUT_S=5.0
VWORLD_RETRIES=3
VWORLD_BACKOFF_S=0.5

# Upload
MAX_UPLOAD_SIZE_MB=10
MAX_UPLOAD_ROWS=5000
UPLOAD_SHEET_NAME=목록

# Web Tracking
# 수집할 페이지 경로 허용 목록 (쉼표 구분, 각 항목은 '/'로 시작, 최대 20개).
# '/'는 모든 경로를 수집함 — 운영 환경에서는 실제 사용 경로만 명시할 것.
# 예: ALLOWED_WEB_TRACK_PATHS=/,/about
ALLOWED_WEB_TRACK_PATHS=/

# Public Download
PUBLIC_DOWNLOAD_MAX_SIZE_MB=25
PUBLIC_DOWNLOAD_RATE_LIMIT_PER_MINUTE=10
PUBLIC_DOWNLOAD_ALLOWED_EXTS=pdf,csv,xlsx
PUBLIC_DOWNLOAD_DIR=data/public_download

# Raw Query Export
# 1회 CSV export 최대 행 수 상한
RAW_QUERY_EXPORT_MAX_ROWS=100000
# export 쿼리 실행 제한 시간(초)
RAW_QUERY_EXPORT_TIMEOUT_S=30.0

# Proxy Trust
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=
